{
  "name": "ashtangamoon",
  "version": "3.0.0",
  "description": "Shows the current moon phase and the next new and full moon. Computed locally - no location, no network.",
  "type": "module",
  "scripts": {
    "dev": "PWA_DISABLE=true vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "deploy": "firebase deploy"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-minify": "^3.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "keywords": [
    "pwa",
    "moon",
    "moon-phase",
    "new-moon",
    "full-moon",
    "yoga",
    "ashtanga",
    "ashtanga-yoga"
  ],
  "author": "Konstantin Komelin <konstantin.komelin@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0"
}
